# ---- Secrets / local config ----
.env
.env.local
*.local
# Application Default Credentials and service-account keys must never be committed.
*-credentials.json
*-sa.json
gcp-*.json
adc.json

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# ---- Node / Next.js (web/) ----
node_modules/
.next/
out/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ---- Simulation artifacts ----
# Recorded NDJSON runs and cached replays are generated, not source.
runs/
*.ndjson
/replays/
# …but a curated cached replay committed under docs/ is a source asset (the
# offline demo streams it), so keep those.
!docs/**/*.ndjson

# ---- Terraform ----
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# ---- Editor / OS ----
.DS_Store
.idea/
.vscode/
*.swp
