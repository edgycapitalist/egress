# Egress environment configuration. Copy to `.env` and fill in. Never commit `.env`.
#
# =============================================================================
# GEMINI / VERTEX AI AUTHENTICATION — READ THIS FIRST
# =============================================================================
# Gemini is called ONLY through Vertex AI, never through Google AI Studio.
# Authenticate with Application Default Credentials (ADC):
#
#     gcloud auth application-default login
#
# and set the project and location below. The agents read the project from this
# file, NOT from `gcloud config`.
#
# Do NOT set GOOGLE_API_KEY. An AI Studio API key must never be used in this
# project. The flag below routes the google-genai / ADK clients to Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Optional: explicit path to a service-account key for non-interactive
# environments. Prefer ADC / workload identity. If unset, ADC is used.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/adc.json

# =============================================================================
# Gemini model selection
# =============================================================================
# Fast model for the archetype mood-setters (they run repeatedly, every k ticks).
GEMINI_MODEL_FAST=gemini-2.5-flash
# Stronger model for the analyst and the calibration critic.
GEMINI_MODEL_STRONG=gemini-3.1-pro

# =============================================================================
# Vertex AI Search (RAG grounding) and Memory Bank
# =============================================================================
# Datastore / engine id for the historical-crisis + microstructure corpus.
VERTEX_SEARCH_DATASTORE_ID=
# Vertex AI Memory Bank (ADK MemoryService). Leave blank to use the pgvector
# local fallback for calibration memory and scenario history.
VERTEX_MEMORY_BANK_ID=

# =============================================================================
# Data layer (docker-compose provides these locally)
# =============================================================================
DATABASE_URL=postgresql://egress:egress@localhost:5432/egress
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Service URLs (local defaults; overridden by Cloud Run in deployment)
# =============================================================================
GATEWAY_URL=http://localhost:8080
ENGINE_URL=http://localhost:8000
MARKET_DATA_MCP_URL=http://localhost:8101
NEWS_MCP_URL=http://localhost:8102

# =============================================================================
# Third-party data sources (declare every one of these in the submission)
# =============================================================================
# Alpha Vantage (free, no card): https://www.alphavantage.co/support/#api-key
# Backs BOTH MCP servers — TIME_SERIES_DAILY for market data and NEWS_SENTIMENT
# for news. Leave blank to run on the deterministic synthetic fallback (offline,
# zero network). The free tier is ~25 calls/day; the MCPs cache every response in
# Postgres keyed by symbol+period, so a run makes at most a few real calls.
ALPHAVANTAGE_API_KEY=
MARKET_DATA_API_KEY=
NEWS_API_KEY=

# =============================================================================
# Run modes — keep most development free of LLM cost
# =============================================================================
# DETERMINISTIC_BASELINE=true makes archetype stances come from fixed heuristics
# instead of Gemini, so the whole system runs with zero LLM calls.
DETERMINISTIC_BASELINE=true
# CACHED_REPLAY=true serves a recorded NDJSON run instead of executing live.
CACHED_REPLAY=false
# Master seed for reproducible runs.
EGRESS_SEED=42
